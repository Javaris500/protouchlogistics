# ProTouch Logistics — environment template.
#
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
# All keys below are validated at module load by `src/server/env.ts` —
# the app refuses to boot if a required key is missing or empty.
#
# ---------------------------------------------------------------------------

# Postgres connection string. Source: Railway → your Postgres service →
# "Connect" tab → "Postgres Connection URL".
# Format: postgresql://user:pass@host:port/db
DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# Better Auth signing secret. 32 random bytes, base64-encoded.
# Generate locally with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotate this and every existing session is invalidated.
BETTER_AUTH_SECRET=replace-with-32-bytes-of-randomness-base64

# Public origin for Better Auth cookie domain + trustedOrigins. In dev this
# may be omitted (defaults to http://localhost:3000). In Vercel previews
# and production, set this to the deployed URL — without it, cross-origin
# sign-in requests are rejected.
BETTER_AUTH_URL=http://localhost:3000

# Vercel Blob read/write token. Source: Vercel dashboard → Storage → Blob →
# your store → ".env.local" tab. Required by uploadDoc / deleteBlob /
# blobExists in src/server/storage and by the blob read in src/server/ai.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx

# Vercel AI Gateway API key. Source: Vercel dashboard → AI → Gateway → API
# keys. Used by extractCdl / extractMedicalCard against
# "anthropic/claude-haiku-4-5".
AI_GATEWAY_API_KEY=vck_xxxxxxxxxxxxxxxxxxxxxxxx

# Bootstrap admin (Gary) — consumed once by `npm run seed:admin`.
# Pick a strong password (≥12 chars). The admin is forced to rotate it on
# first sign-in via the firstLoginCompletedAt gate.
ADMIN_SEED_EMAIL=gary@protouchlogistics.com
ADMIN_SEED_PASSWORD=replace-with-strong-password-min-12-chars

# ---------------------------------------------------------------------------
# Notes:
#
# - VERCEL_OIDC_TOKEN appears in `.env.local` after `vercel env pull` runs.
#   It's set by Vercel and consumed by Vercel's tooling, not by app code.
#
# - drizzle-kit reads `.env.local` first, then `.env` (see drizzle.config.ts),
#   so put real values in `.env.local` and keep `.env` empty.
