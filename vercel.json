{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/client/(.*)", "destination": "/client/$1" },
    { "source": "/(.*)", "destination": "/api" }
  ]
}
